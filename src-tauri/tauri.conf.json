{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Keynova",
  "version": "0.1.0",
  "identifier": "com.keynova.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Keynova",
        "width": 640,
        "height": 60,
        "minWidth": 640,
        "minHeight": 56,
        "transparent": true,
        "decorations": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost http://localhost:* ws://localhost:* https://translate.googleapis.com https://api.anthropic.com https://api.openai.com; img-src 'self' data: asset: https://asset.localhost; object-src 'none'; frame-src 'none'; base-uri 'self'; worker-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
