{
  "name": "tauri-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "keynova": "cargo run --manifest-path src-tauri/Cargo.toml --bin keynova --",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
